# NCP endpoint reachable from inside an Omnigent-wrapped (sandboxed) session.
#
# Omnigent's runner puts each agent session in a sandbox, so the NCP bus is
# usually NOT on the session's own loopback. Bind `ncp serve` to an address the
# sandbox can reach and require a bearer token (never bind off-loopback without
# one).
#
# Host the sandbox uses to reach the machine running `ncp serve`.
# On the NCP host itself this is 127.0.0.1; from a sandbox it is the host's
# LAN/bridge address (e.g. 172.17.0.1 for a default Docker bridge, or a hostname).
NCP_HOST=127.0.0.1

# Must match [server].auth_token in .ncp/config.toml, or the token passed to
# `ncp serve --auth-token` / NCP_AUTH_TOKEN when the bus was started.
NCP_AUTH_TOKEN=replace-with-a-long-random-token
